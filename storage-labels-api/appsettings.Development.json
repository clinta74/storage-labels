{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "RateLimit": {
    "Global": {
      "PermitLimit": 1000,
      "WindowSeconds": 60
    },
    "Auth": {
      "PermitLimit": 50,
      "WindowSeconds": 60
    },
    "Search": {
      "TokenLimit": 1000
    }
  },
  "Jwt": {
        "Secret": "your-secret-key-min-32-chars-change-in-production",
        "Issuer": "storage-labels-api",
        "Audience": "storage-labels-ui",
        "ExpirationMinutes": 2
    },
    "RefreshTokens": {
        "CookieName": "sl_refresh_token",
        "LifetimeMinutes": 1440,
        "PersistentLifetimeDays": 30
    }
}